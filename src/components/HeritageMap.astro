---
/* Bản đồ & Trải nghiệm khám phá — lưới thẻ KHÔNG GIAN VR theo tầng.
   ⚠️ Thẻ khu vực render Ở CLIENT từ /data/spaces.json (admin sửa file đó
   qua GitHub API) — web cập nhật nội dung KHÔNG cần build lại. */
import { UI } from '../content/site';
const vi = UI.vi, en = UI.en;
---

<section id="ban-do" class="map-section relative">
  <div class="map-heading reveal">
    <h2 class="map-title-figma">
      <span data-vi-text={vi.mapTitle1} data-en-text={en.mapTitle1}>{vi.mapTitle1}</span>
      <span data-vi-text={vi.mapTitle2} data-en-text={en.mapTitle2}>{vi.mapTitle2}</span>
    </h2>
    <p data-vi-text={vi.mapSub} data-en-text={en.mapSub}>{vi.mapSub}</p>
  </div>

  <div class="max-w-[1100px] mx-auto px-5 md:px-8">
    <div class="text-center mb-9 reveal">
      <span class="floor-pill" data-vi-text={vi.floor1} data-en-text={en.floor1}>{vi.floor1}</span>
    </div>
    <div class="map-cards" data-floor-grid="1"></div>

    <div class="text-center mt-16 mb-9 reveal">
      <span class="floor-pill" data-vi-text={vi.floor2} data-en-text={en.floor2}>{vi.floor2}</span>
    </div>
    <div class="map-cards" data-floor-grid="2"></div>

    <div class="text-center mt-16 md:mt-20 reveal">
      <button class="cta-vr" data-cta>
        <img src="/assets/figma/ic-atom-white.svg" alt="" aria-hidden="true" />
        <span data-vi-text={vi.cta} data-en-text={en.cta}>{vi.cta}</span>
      </button>
    </div>
  </div>
</section>

<style is:global>
  /* ===== Bản đồ — heading + thẻ khu vực + CTA =====
     (is:global vì thẻ khu vực được render bằng JS lúc chạy) */
  .map-section{ padding:69px 0 112px; scroll-margin-top:72px; overflow:visible; }
  .map-heading{ max-width:100%; margin:0 auto 102px; padding:0; text-align:center; }
  .map-title-figma{
    display:flex; flex-direction:column; align-items:center;
    width:min(1711px,calc(100vw - 56px));
    font-family:var(--hv); font-weight:800; font-style:normal;
    text-transform:uppercase; letter-spacing:0; line-height:1.07;
    font-size:clamp(58px,6.68vw,128px);
    background:var(--grad-gold-display);
    -webkit-background-clip:text; background-clip:text; color:transparent;
    filter:drop-shadow(0 18px 9px rgba(226,169,80,.24));
    overflow:visible;
    /* nới vùng nền cho dấu tiếng Việt trên chữ HOA (xem chú thích .text-goldgrad) */
    padding:.18em .06em .1em; margin:-.18em auto -.1em;
  }
  .map-title-figma span{
    display:block; white-space:nowrap; line-height:1.07; overflow:visible;
  }
  .map-heading p{
    margin-top:34px; color:#E0912C; font-family:var(--hv);
    font-size:clamp(15px,1.2vw,18px); font-style:italic; line-height:1.35;
  }
  @media(max-width:1023px){
    .map-section{ padding:72px 0 96px; }
    .map-heading{ margin-bottom:76px; padding:0 18px; }
    .map-title-figma{ width:100%; font-size:clamp(42px,10vw,86px); }
    .map-title-figma span{ max-width:100%; white-space:normal; }
  }
  @media(max-width:639px){
    .map-title-figma{ font-size:clamp(34px,12vw,54px); }
  }

  .floor-pill{ display:inline-block; font-family:var(--hv); font-style:italic; font-weight:700;
    color:var(--brown); background:#fff; border:1px solid rgba(230,149,46,.40);
    border-radius:9999px; padding:9px 34px; font-size:clamp(17px,1.5vw,21px);
    box-shadow:var(--shadow-pill); }

  .map-cards{ display:flex; flex-wrap:wrap; justify-content:center; gap:24px; max-width:1000px; margin:0 auto; }
  .map-card{ width:calc((100% - 48px)/3); position:relative; cursor:pointer; padding-bottom:16px; }
  @media(max-width:780px){ .map-card{ width:calc((100% - 24px)/2); } }
  @media(max-width:520px){ .map-card{ width:100%; } }

  .map-card .body{ position:relative; aspect-ratio:7/5; border-radius:16px;
    background:var(--orange); display:grid; place-items:center; overflow:hidden;
    box-shadow:var(--shadow-tile);
    transition:transform .5s cubic-bezier(.2,.7,.2,1), box-shadow .5s; }
  .map-card:hover .body{ transform:translateY(-5px); box-shadow:0 34px 60px -26px rgba(185,110,20,.72); }
  /* ảnh preview cho khu vực ĐÃ có ảnh 360° */
  .map-card .body > .photo{ position:absolute; inset:0; border-radius:16px; z-index:0;
    background-size:cover; background-position:center;
    transform:scale(1.01) rotate(0);
    transition:transform .65s cubic-bezier(.2,.75,.2,1); }
  .map-card:hover .body > .photo{ transform:scale(1.09) rotate(1.5deg); }
  .map-card:nth-child(even):hover .body > .photo{ transform:scale(1.09) rotate(-1.5deg); }
  .map-card .body > .tint{ position:absolute; inset:0; border-radius:16px; z-index:1;
    background:linear-gradient(180deg, rgba(230,149,46,.15) 0%, rgba(196,116,20,.50) 100%); }
  .map-card.has-photo .body{ background:#C9842E; }
  .map-card .disc{ position:relative; z-index:2; width:23%; height:auto; aspect-ratio:1;
    filter:drop-shadow(0 8px 18px rgba(58,36,8,.32));
    transition:transform .45s cubic-bezier(.34,1.4,.5,1); }
  .map-card:hover .disc{ transform:scale(1.12); }
  .map-card .plate{ position:absolute; z-index:3; left:50%; bottom:0; transform:translateX(-50%);
    min-width:74%; max-width:94%; text-align:center; white-space:nowrap;
    background:var(--paper); color:var(--orange2);
    font-family:var(--hv); font-weight:600; font-size:clamp(13px,1.05vw,15px);
    padding:9px 20px; border-radius:12px;
    box-shadow:var(--shadow-plate);
    overflow:hidden; text-overflow:ellipsis; }
  .map-card:focus-visible{ outline:none; }
  .map-card:focus-visible .body{ box-shadow:0 0 0 3px rgba(230,149,46,.7), var(--shadow-tile); }

  /* nút VR 360° lớn (vàng gradient) */
  .cta-vr{ display:inline-flex; align-items:center; gap:14px;
    background:var(--grad-gold-btn);
    color:#fff; font-family:var(--hv); font-weight:600; border-radius:9999px;
    padding:16px 44px; font-size:clamp(17px,1.5vw,20px); cursor:pointer; border:none;
    box-shadow:var(--shadow-btn);
    transition:transform .25s, filter .25s; }
  .cta-vr:hover{ transform:translateY(-2px); filter:brightness(1.04); }
  .cta-vr img{ width:30px; height:30px; }
  @media (prefers-reduced-motion: reduce){
    .map-card .body > .photo{ transition:none; }
    .map-card:hover .body > .photo,
    .map-card:nth-child(even):hover .body > .photo{ transform:scale(1.01); }
  }
</style>

<script>
  /* Tải /data/spaces.json → window.SPACES → render thẻ khu vực theo tầng.
     Bấm thẻ / CTA → window.openVR(idx) (VRViewer.astro cung cấp). */

  // ảnh preview: ưu tiên thumb → ảnh cảnh đầu tiên → photo
  function previewOf(s: any): string {
    return s.thumb
      || (s.scenes && (s.scenes.find((sc: any) => sc && sc.photo) || {}).photo)
      || s.photo || '';
  }

  function cardHTML(s: any, gi: number): string {
    const lang = (window as any).__lang?.() || 'vi';
    const labelVi = s.card?.vi ?? '';
    const labelEn = s.card?.en ?? labelVi;
    const label = lang === 'vi' ? labelVi : labelEn;
    const prev = previewOf(s);
    const bg = prev
      ? `<div class="photo" style="background-image:url('${prev}')"></div><div class="tint"></div>`
      : '';
    return `<div class="map-card reveal${prev ? ' has-photo' : ''}" role="button" tabindex="0"
         aria-label="${label}" title="${label}" data-zone data-idx="${gi}">
      <div class="body">
        ${bg}
        <img class="disc" src="/assets/figma/icon360.svg" alt="" aria-hidden="true">
        <div class="plate" data-vi-text="${labelVi}" data-en-text="${labelEn}">${label}</div>
      </div>
    </div>`;
  }

  function renderCards() {
    const SPACES: any[] = (window as any).SPACES || [];
    for (const floor of [1, 2]) {
      const grid = document.querySelector<HTMLElement>(`[data-floor-grid="${floor}"]`);
      if (!grid) continue;
      // gi = chỉ số toàn cục trong SPACES (mở đúng không gian VR)
      grid.innerHTML = SPACES
        .map((s, gi) => ({ s, gi }))
        .filter((o) => (o.s.floor || 1) === floor)
        .map((o) => cardHTML(o.s, o.gi))
        .join('');
    }
    wireClicks();
    (window as any).__rescanReveal?.();
  }

  function wireClicks() {
    document.querySelectorAll<HTMLElement>('[data-zone]').forEach((card) => {
      const idx = +(card.dataset.idx || 0);
      const fire = () => {
        const b = card.querySelector('.disc');
        b?.animate(
          [{ transform: 'scale(1)' }, { transform: 'scale(.86)' }, { transform: 'scale(1.12)' }],
          { duration: 300, easing: 'cubic-bezier(.34,1.5,.5,1)' });
        (window as any).openVR?.(idx);
      };
      card.addEventListener('click', fire);
      card.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fire(); }
      });
    });
  }

  const cta = document.querySelector<HTMLElement>('[data-cta]');
  cta?.addEventListener('click', () => {
    cta.animate(
      [{ transform: 'translateY(-2px) scale(1)' }, { transform: 'translateY(-2px) scale(.96)' }, { transform: 'translateY(-2px) scale(1)' }],
      { duration: 300, easing: 'ease-out' });
    (window as any).openVR?.(0);
  });

  // tải danh sách không gian (no-store: admin vừa lưu là thấy ngay sau refresh)
  (async () => {
    try {
      const res = await fetch('/data/spaces.json', { cache: 'no-store' });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      (window as any).SPACES = await res.json();
    } catch (e) {
      (window as any).SPACES = [];
      console.error('Không tải được data/spaces.json:', e);
    }
    renderCards();
  })();

  document.addEventListener('langchange', renderCards);
</script>
