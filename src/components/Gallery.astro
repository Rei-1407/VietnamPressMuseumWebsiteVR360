---
/* Gallery — "Mục ảnh": 2 HÀNG ảnh bảo tàng tự cuộn ngược chiều nhau + lightbox.
   - Hàng trên: phải → trái ; Hàng dưới: trái → phải.
   - Tự chạy khi để yên; người dùng có thể KÉO / LĂN / VUỐT để tự cuộn (tạm dừng
     tự chạy khi tương tác, rồi chạy tiếp).
   ⚠️ Ảnh render Ở CLIENT từ /data/gallery.json (admin sửa file đó qua GitHub API). */
---

<section id="muc-anh" class="gallery-section reveal" aria-label="Hình ảnh bảo tàng"
         data-vi-aria-label="Hình ảnh bảo tàng" data-en-aria-label="Museum gallery">
  <div class="gallery-band">
    <div class="gallery-row" data-gallery-row data-dir="1"><div class="gallery-track" data-gallery-track></div></div>
    <div class="gallery-row" data-gallery-row data-dir="-1"><div class="gallery-track" data-gallery-track></div></div>
  </div>
</section>

<!-- Lightbox (đặt NGOÀI section reveal để tránh stacking-context của transform) -->
<div class="gallery-lightbox" data-lightbox hidden aria-hidden="true" role="dialog" aria-modal="true"
     aria-label="Xem ảnh" data-vi-aria-label="Xem ảnh" data-en-aria-label="Image viewer">
  <button class="gl-close" data-gl-close type="button" aria-label="Đóng"
          data-vi-aria-label="Đóng" data-en-aria-label="Close">✕</button>
  <button class="gl-nav gl-prev" data-gl-prev type="button" aria-label="Ảnh trước"
          data-vi-aria-label="Ảnh trước" data-en-aria-label="Previous image">‹</button>
  <img class="gl-img" data-gl-img alt="" />
  <button class="gl-nav gl-next" data-gl-next type="button" aria-label="Ảnh sau"
          data-vi-aria-label="Ảnh sau" data-en-aria-label="Next image">›</button>
</div>

<style is:global>
  /* ===== Mục ảnh — dải cam 2 hàng (is:global vì item render bằng JS lúc chạy) ===== */
  .gallery-section{ position:relative; width:100%; margin:clamp(10px,2vw,28px) 0; scroll-margin-top:84px; }
  .gallery-band{
    position:relative; width:100%; overflow:hidden;
    background:var(--orange);
    padding:clamp(22px,2.8vw,42px) 0;
    box-shadow:inset 0 14px 26px -20px rgba(58,36,8,.55), inset 0 -14px 26px -20px rgba(58,36,8,.55);
  }
  /* mép mờ hai bên để ảnh "trôi" vào/ra êm (trên cùng, không chặn thao tác) */
  .gallery-band::before, .gallery-band::after{
    content:""; position:absolute; top:0; bottom:0; width:clamp(40px,7vw,120px); z-index:3; pointer-events:none;
  }
  .gallery-band::before{ left:0;  background:linear-gradient(90deg, var(--orange), transparent); }
  .gallery-band::after{  right:0; background:linear-gradient(270deg, var(--orange), transparent); }

  /* mỗi hàng = vùng cuộn ngang (ẩn thanh cuộn); cho kéo tay bằng chuột */
  .gallery-row{
    overflow-x:auto; overflow-y:hidden; cursor:grab;
    scroll-behavior:auto;               /* QUAN TRỌNG: ghi đè *{scroll-behavior:smooth}
                                           để gán scrollLeft tức thì (rAF cộng dồn được) */
    scrollbar-width:none; -ms-overflow-style:none;
    touch-action:pan-x;                 /* vuốt ngang cuộn hàng, vuốt dọc cuộn trang */
    -webkit-overflow-scrolling:touch;
  }
  .gallery-row::-webkit-scrollbar{ display:none; }
  .gallery-row.dragging{ cursor:grabbing; }
  .gallery-row + .gallery-row{ margin-top:clamp(14px,1.6vw,24px); }

  .gallery-track{ display:flex; width:max-content; }

  /* item = khung trắng kiểu polaroid; margin-right (không flex-gap) để 2 "bộ" rộng
     bằng nhau → vòng lặp scrollLeft liền mạch */
  .gallery-item{
    flex:0 0 auto; margin-right:clamp(14px,1.7vw,26px);
    padding:clamp(7px,0.8vw,12px) clamp(7px,0.8vw,12px) clamp(11px,1.3vw,18px);
    background:#fff; border:none; border-radius:6px; cursor:pointer;
    box-shadow:0 18px 34px -20px rgba(58,36,8,.6), 0 2px 6px -3px rgba(58,36,8,.3);
    transition:transform .45s cubic-bezier(.2,.7,.2,1), box-shadow .45s;
  }
  .gallery-item:hover{
    transform:translateY(-6px) scale(1.015);
    box-shadow:0 30px 50px -22px rgba(58,36,8,.7), 0 3px 8px -3px rgba(58,36,8,.35);
  }
  .gallery-item:active{ transform:translateY(-3px) scale(.99); }
  .gallery-item .photo{
    display:block; width:clamp(190px,20vw,264px); aspect-ratio:4/3;
    object-fit:cover; border-radius:3px; background:#e7ddcf; user-select:none; -webkit-user-drag:none;
  }
  @media (prefers-reduced-motion: reduce){ .gallery-item{ transition:none; } }

  /* ===== Lightbox ===== */
  .gallery-lightbox{
    position:fixed; inset:0; z-index:90; display:none; place-items:center;
    background:rgba(20,12,4,.93); -webkit-backdrop-filter:blur(4px); backdrop-filter:blur(4px);
  }
  .gallery-lightbox.open{ display:grid; animation:gl-fade .25s ease both; }
  @keyframes gl-fade{ from{ opacity:0; } to{ opacity:1; } }
  .gl-img{
    max-width:92vw; max-height:86vh; object-fit:contain; border-radius:6px;
    box-shadow:0 40px 90px -20px rgba(0,0,0,.8); background:#1a140b;
    animation:gl-zoom .3s cubic-bezier(.2,.7,.2,1) both;
  }
  @keyframes gl-zoom{ from{ opacity:0; transform:scale(.96); } to{ opacity:1; transform:none; } }
  .gl-close, .gl-nav{
    position:fixed; z-index:1; display:grid; place-items:center;
    color:#fff; background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.25);
    border-radius:9999px; cursor:pointer; backdrop-filter:blur(4px);
    transition:background .2s, transform .2s;
  }
  .gl-close:hover, .gl-nav:hover{ background:rgba(255,255,255,.22); }
  .gl-close{ top:clamp(14px,3vw,28px); right:clamp(14px,3vw,28px); width:46px; height:46px; font-size:20px; }
  .gl-nav{ top:50%; transform:translateY(-50%); width:54px; height:54px; font-size:34px; line-height:1; padding-bottom:4px; }
  .gl-nav:hover{ transform:translateY(-50%) scale(1.08); }
  .gl-prev{ left:clamp(10px,2.5vw,30px); }
  .gl-next{ right:clamp(10px,2.5vw,30px); }
  @media (max-width:560px){
    .gl-nav{ width:44px; height:44px; font-size:28px; }
    .gl-close{ width:40px; height:40px; }
  }
  @media (prefers-reduced-motion: reduce){
    .gallery-lightbox.open, .gl-img{ animation:none; }
  }
</style>

<script>
  /* Tải /data/gallery.json → dựng 2 hàng tự cuộn ngược chiều + cho cuộn tay + lightbox. */
  const section = document.getElementById('muc-anh');
  const band = section?.querySelector<HTMLElement>('.gallery-band');
  const rows = section ? Array.from(section.querySelectorAll<HTMLElement>('[data-gallery-row]')) : [];
  const lb = document.querySelector<HTMLElement>('[data-lightbox]');
  const lbImg = lb?.querySelector<HTMLImageElement>('[data-gl-img]');
  if (section && band && rows.length === 2 && lb && lbImg) {

    const noFx = /[?&]nofx/.test(location.search)
      || matchMedia('(prefers-reduced-motion: reduce)').matches;
    const SPEED = 42;          // px/giây cho phần tự cuộn

    const url = (p: string) => !p ? '' : (p.startsWith('http') ? p : '/' + p.replace(/^\/+/, ''));
    const thumbOf = (it: any) => url(it.thumb || it.src);
    const fullOf = (it: any) => url(it.src || it.thumb);

    let items: any[] = [];
    let cur = 0;
    let justDragged = false;   // vừa kéo → bỏ qua click mở lightbox

    // preload ảnh full kế bên → bấm ◀▶ chuyển gần như tức thì
    const preloaded: Record<string, HTMLImageElement> = {};
    function preload(i: number) {
      if (!items.length) return;
      const k = (i % items.length + items.length) % items.length;
      const u = fullOf(items[k]);
      if (!u || preloaded[u]) return;
      const im = new Image(); im.src = u; preloaded[u] = im;
    }

    function itemHTML(gi: number, dup: boolean) {
      const it = items[gi];
      const hid = dup ? ' tabindex="-1" aria-hidden="true"' : '';
      return `<button class="gallery-item" type="button" data-gi="${gi}"${hid}
        aria-label="Xem ảnh lớn" data-vi-aria-label="Xem ảnh lớn" data-en-aria-label="View larger image">
        <img class="photo" src="${thumbOf(items[gi])}" alt="" loading="lazy" decoding="async" draggable="false">
      </button>`;
    }

    // dựng nội dung 1 hàng = 2 "bộ" giống hệt (để cuộn vòng) ; trả về bề rộng 1 bộ
    function buildRow(rowEl: HTMLElement, order: number[]) {
      const track = rowEl.querySelector<HTMLElement>('[data-gallery-track]')!;
      track.innerHTML = order.map((gi) => itemHTML(gi, false)).join('');
      const oneW = track.scrollWidth || 1;
      const reps = Math.max(1, Math.ceil((rowEl.clientWidth * 1.6) / oneW));
      let a = '', b = '';
      for (let r = 0; r < reps; r++) {
        a += order.map((gi) => itemHTML(gi, false)).join('');
        b += order.map((gi) => itemHTML(gi, true)).join('');
      }
      track.innerHTML = a + b;
      return track.scrollWidth / 2;
    }

    function setupRow(rowEl: HTMLElement, order: number[]) {
      const dir = +(rowEl.dataset.dir || '1');     // 1: phải→trái ; -1: trái→phải
      let setW = buildRow(rowEl, order);
      rowEl.scrollLeft = dir > 0 ? 0 : setW;

      let hovering = false, pointerActive = false, downX = 0, downScroll = 0;
      let last = performance.now();

      function tick(now: number) {
        const dt = Math.min(64, now - last); last = now;
        if (!noFx && !hovering && !pointerActive && setW > 0) {
          rowEl.scrollLeft += dir * SPEED * dt / 1000;
          if (rowEl.scrollLeft >= setW) rowEl.scrollLeft -= setW;        // vòng lặp liền mạch
          else if (rowEl.scrollLeft <= 0) rowEl.scrollLeft += setW;
        }
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);

      // hover (chuột) → tạm dừng tự chạy, cho lăn/kéo tay
      rowEl.addEventListener('pointerenter', (e) => { if (e.pointerType === 'mouse') hovering = true; });
      rowEl.addEventListener('pointerleave', (e) => { if (e.pointerType === 'mouse') { hovering = false; last = performance.now(); } });

      // kéo-để-cuộn (chuột) ; chạm thì để trình duyệt cuộn tự nhiên (pan-x)
      rowEl.addEventListener('pointerdown', (e) => {
        pointerActive = true; justDragged = false; downX = e.clientX; downScroll = rowEl.scrollLeft;
        if (e.pointerType === 'mouse') rowEl.classList.add('dragging');
      });
      rowEl.addEventListener('pointermove', (e) => {
        if (!pointerActive) return;
        const dx = e.clientX - downX;
        if (Math.abs(dx) > 5) justDragged = true;
        if (e.pointerType === 'mouse') rowEl.scrollLeft = downScroll - dx;
      });
      function up(e: PointerEvent) {
        rowEl.classList.remove('dragging');
        if (e.pointerType === 'mouse') { pointerActive = false; last = performance.now(); }
        else { setTimeout(() => { pointerActive = false; last = performance.now(); }, 600); }  // chờ quán tính chạm
      }
      rowEl.addEventListener('pointerup', up);
      rowEl.addEventListener('pointercancel', up);

      // trả về hàm dựng lại khi đổi kích thước
      return () => { setW = buildRow(rowEl, order); rowEl.scrollLeft = dir > 0 ? 0 : setW; };
    }

    /* ----- lightbox ----- */
    function openLB(i: number) {
      cur = (i % items.length + items.length) % items.length;
      lbImg!.src = fullOf(items[cur]);
      lb!.hidden = false; lb!.classList.add('open'); lb!.setAttribute('aria-hidden', 'false');
      preload(cur + 1); preload(cur - 1);
      document.addEventListener('keydown', onKey);
    }
    function closeLB() {
      lb!.classList.remove('open'); lb!.setAttribute('aria-hidden', 'true');
      lb!.hidden = true; lbImg!.src = '';
      document.removeEventListener('keydown', onKey);
    }
    function onKey(e: KeyboardEvent) {
      if (e.key === 'Escape') closeLB();
      else if (e.key === 'ArrowLeft') openLB(cur - 1);
      else if (e.key === 'ArrowRight') openLB(cur + 1);
    }
    band.addEventListener('click', (e) => {
      const b = (e.target as HTMLElement).closest<HTMLElement>('.gallery-item');
      if (!b || b.dataset.gi == null) return;
      if (justDragged) { justDragged = false; return; }   // vừa kéo thì không mở
      openLB(+b.dataset.gi);
    });
    lb.querySelector('[data-gl-close]')!.addEventListener('click', closeLB);
    lb.querySelector('[data-gl-prev]')!.addEventListener('click', () => openLB(cur - 1));
    lb.querySelector('[data-gl-next]')!.addEventListener('click', () => openLB(cur + 1));
    lb.addEventListener('click', (e) => { if (e.target === lb) closeLB(); });

    /* ----- nạp dữ liệu ----- */
    let rebuilders: Array<() => void> = [];
    let rt: any;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(() => rebuilders.forEach((fn) => fn()), 200);
    });

    (async () => {
      let data: any = [];
      try {
        const r = await fetch('/data/gallery.json', { cache: 'no-store' });
        if (r.ok) data = await r.json();
      } catch (e) { console.error('Không tải được data/gallery.json:', e); }
      items = Array.isArray(data) ? data.filter((x) => x && (x.src || x.thumb)) : [];
      if (!items.length) { section!.style.display = 'none'; return; }

      const baseOrder = items.map((_, i) => i);
      const reversed = baseOrder.slice().reverse();          // hàng dưới đảo thứ tự cho đỡ trùng
      rebuilders = [
        setupRow(rows[0], baseOrder),   // hàng trên: phải → trái
        setupRow(rows[1], reversed),    // hàng dưới: trái → phải
      ];
      (window as any).__rescanReveal?.();
    })();
  }
</script>
