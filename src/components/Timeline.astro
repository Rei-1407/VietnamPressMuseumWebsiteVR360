---
/* Timeline — "Dấu Ấn Lịch Sử Làng Báo": mốc giai đoạn (era) + thẻ sự kiện (event).
   Dữ liệu: TIMELINE trong src/content/site.ts — render tĩnh lúc build,
   chữ song ngữ đổi tại chỗ qua data-vi-text/data-en-text. */
import { UI, TIMELINE, type TimelineItem } from '../content/site';
const vi = UI.vi, en = UI.en;

interface Block { era: TimelineItem; events: TimelineItem[] }
const blocks: Block[] = [];
for (const item of TIMELINE) {
  if (item.kind === 'era') blocks.push({ era: item, events: [] });
  else if (blocks.length) blocks[blocks.length - 1].events.push(item);
}

type TextPart = 't' | 'd';
type BreakSpec = Partial<Record<TextPart, string[]>>;
const viBreaks: Record<string, BreakSpec> = {
  'era:1865 - 1925': { d: ['tờ báo cổ'] },
  'event:1865': { d: ['đầu tiên,'] },
  'event:21.06.1925': { t: ['Cách mạng'], d: ['báo Thanh Niên,'] },
  'era:1925 - 1945': { d: ['vinh danh'] },
  'era:1945 - 1954': { d: ['cùng cuộc'] },
  'event:1949': { t: ['làm', 'tên'] },
  'era:1954 - 1975': { d: ['miền Bắc,'] },
  'event:1972': { d: ['Cùng với đó', 'thời kỳ đầu'] },
  'event:30.04.1975': { t: ['ngày'] },
  'era:1975 - Nay': { d: ['tiên phong'] },
  'event:1986': { d: ['khơi nguồn từ', 'Tổng Bí thư'] },
  'event:Hiện tại': { d: ['chống tiêu cực'] },
};

const keyOf = (item: TimelineItem) => `${item.kind}:${item.year}`;
function splitAfter(text: string, markers?: string[]): string[] {
  if (!markers?.length || !text) return text ? [text] : [''];
  const lines: string[] = [];
  let rest = text;
  for (const marker of markers) {
    const idx = rest.indexOf(marker);
    if (idx < 0) return text ? [text] : [''];
    const end = idx + marker.length;
    lines.push(rest.slice(0, end).trim());
    rest = rest.slice(end).trim();
  }
  if (rest) lines.push(rest);
  return lines.length ? lines : [''];
}
function displayLines(item: TimelineItem, part: TextPart) {
  const viLines = splitAfter(item.vi[part], viBreaks[keyOf(item)]?.[part]);
  const enLines = splitAfter(item.en[part]);
  const count = Math.max(viLines.length, enLines.length);
  return Array.from({ length: count }, (_, i) => ({
    vi: viLines[i] ?? '',
    en: enLines[i] ?? '',
  }));
}
---

<section id="lich-su">
  <div class="tl-heading reveal">
    <div class="tl-kicker text-goldgrad uppercase"
         data-vi-text={vi.histKicker} data-en-text={en.histKicker}>{vi.histKicker}</div>
    <h2 class="tl-title text-goldgrad uppercase"
        data-vi-text={vi.histTitle} data-en-text={en.histTitle}>{vi.histTitle}</h2>
    <p class="tl-subtitle"
       data-vi-text={vi.histSub} data-en-text={en.histSub}>{vi.histSub}</p>
  </div>

  <div class="tl-wrap">
    {blocks.map((block, index) => (
      <div class={`tl-block tl-block-${index + 1} ${block.events.length ? 'has-events' : 'no-events'}`} data-reveal-group>
        {(index === 0 || index === blocks.length - 1) && <div class="tl-decor" aria-hidden="true"></div>}

        <div class="tl-era-card tl-card reveal">
          <div class="tl-card-body"></div>
          <div class="tl-year" data-vi-text={block.era.year} data-en-text={block.era.yearEn ?? block.era.year}>{block.era.year}</div>
          <div class="tl-card-copy">
            <h3 aria-label={block.era.vi.t}
                data-vi-aria-label={block.era.vi.t} data-en-aria-label={block.era.en.t}>
              {displayLines(block.era, 't').map((line) => (
                <span class="tl-line" data-vi-text={line.vi} data-en-text={line.en}>{line.vi}</span>
              ))}
            </h3>
            <p aria-label={block.era.vi.d}
               data-vi-aria-label={block.era.vi.d} data-en-aria-label={block.era.en.d}>
              {displayLines(block.era, 'd').map((line) => (
                <span class="tl-line" data-vi-text={line.vi} data-en-text={line.en}>{line.vi}</span>
              ))}
            </p>
          </div>
        </div>

        {block.events.length > 0 && (
          <div class={`tl-events ${block.events.length === 1 ? 'single' : 'double'}`}>
            {block.events.map((event) => (
              <div class="tl-event-card tl-card reveal">
                <div class="tl-card-body"></div>
                <div class="tl-year" data-vi-text={event.year} data-en-text={event.yearEn ?? event.year}>{event.year}</div>
                <div class="tl-card-copy">
                  <h3 aria-label={event.vi.t}
                      data-vi-aria-label={event.vi.t} data-en-aria-label={event.en.t}>
                    {displayLines(event, 't').map((line) => (
                      <span class="tl-line" data-vi-text={line.vi} data-en-text={line.en}>{line.vi}</span>
                    ))}
                  </h3>
                  <p aria-label={event.vi.d}
                     data-vi-aria-label={event.vi.d} data-en-aria-label={event.en.d}>
                    {displayLines(event, 'd').map((line) => (
                      <span class="tl-line" data-vi-text={line.vi} data-en-text={line.en}>{line.vi}</span>
                    ))}
                  </p>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
</section>

<style is:global>
  /* ===== Timeline — tỷ lệ desktop dựa trên frame Figma 1920px ===== */
  #lich-su{
    position:relative;
    overflow:hidden;
    background:#fff;
    padding:clamp(70px,4.58vw,88px) 0 clamp(72px,5.47vw,105px);
  }

  .tl-heading{
    position:relative;
    z-index:2;
    width:min(92vw,1425px);
    margin:0 auto clamp(70px,5.2vw,100px);
    text-align:center;
  }
  .tl-kicker,.tl-title{
    font-family:var(--hv);
    font-weight:800;
    font-size:clamp(39px,5.52vw,106px);
    line-height:.93;
    letter-spacing:.01em;
  }
  .tl-title{ white-space:nowrap; }
  .tl-subtitle{
    max-width:72ch;
    margin:clamp(18px,1.2vw,23px) auto 0;
    color:var(--orange2);
    font-family:var(--hv);
    font-size:clamp(12px,1.25vw,24px);
    font-style:italic;
    font-weight:300;
    line-height:1.35;
  }

  .tl-wrap{
    position:relative;
    z-index:1;
    width:100%;
    max-width:1920px;
    margin:0 auto;
  }
  .tl-block{
    --event-gap:clamp(52px,4.15vw,80px);
    position:relative;
    z-index:1;
    margin-bottom:clamp(78px,6.05vw,116px);
  }
  .tl-block-1{ margin-bottom:clamp(70px,4.95vw,95px); }
  .tl-block-2{ margin-bottom:clamp(82px,6.25vw,120px); }
  .tl-block-3{ --event-gap:clamp(46px,3.35vw,64px); }
  .tl-block-4{ margin-bottom:clamp(96px,7.8vw,150px); }
  .tl-block:last-child{ margin-bottom:0; }

  .tl-decor{
    position:absolute;
    z-index:-1;
    top:clamp(86px,6.95vw,133px);
    left:50%;
    width:100vw;
    height:clamp(256px,26.72vw,513px);
    transform:translateX(-50%);
    background:url('/assets/figma/timeline/decor-strip.png') center/cover no-repeat;
    pointer-events:none;
  }

  .tl-card{
    position:relative;
    z-index:1;
    aspect-ratio:2.179 / 1;
    margin-inline:auto;
    text-align:center;
  }
  .tl-card-body{
    position:absolute;
    inset:15.4% 0 0;
    border-radius:clamp(15px,1.72vw,33px);
  }
  .tl-year{
    position:absolute;
    z-index:2;
    top:0;
    left:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    width:70.6%;
    height:38.9%;
    transform:translateX(-50%);
    border-radius:clamp(15px,1.75vw,34px);
    font-family:var(--hv);
    font-size:clamp(25px,3.75vw,72px);
    font-style:italic;
    font-weight:300;
    line-height:1;
    white-space:nowrap;
  }
  .tl-card-copy{
    position:absolute;
    z-index:2;
    top:45.5%;
    right:6%;
    left:6%;
    display:flex;
    height:46%;
    flex-direction:column;
    align-items:center;
  }
  .tl-card-copy h3{
    font-family:var(--hv);
    font-size:clamp(14px,2.08vw,40px);
    font-weight:700;
    line-height:1.08;
    text-transform:uppercase;
  }
  .tl-card-copy .tl-line{
    display:block;
  }
  .tl-card-copy .tl-line:empty{
    display:none;
  }
  .tl-card-copy p{
    margin-top:auto;
    margin-bottom:4%;
    font-family:var(--hv);
    font-size:clamp(9px,1.25vw,24px);
    font-weight:300;
    line-height:1.22;
  }

  .tl-era-card{ width:min(46.43vw,892px); }
  .tl-era-card .tl-card-body{
    border:1px solid rgba(129,78,0,.58);
    background:#fff;
  }
  .tl-era-card .tl-year{
    border:1px solid rgba(129,78,0,.58);
    background:#fff;
    color:var(--brown);
  }
  .tl-era-card .tl-card-copy{ color:var(--brown); }

  .tl-events{
    position:relative;
    z-index:2;
    display:flex;
    align-items:flex-start;
    justify-content:center;
    gap:min(8.6vw,165px);
    width:100%;
    margin-top:var(--event-gap);
  }
  .tl-event-card{ width:min(40.1vw,770px); color:#fff; }
  .tl-event-card .tl-card-copy{
    right:4%;
    left:4%;
  }
  .tl-event-card .tl-card-body{
    border:1px solid rgba(255,255,255,.95);
    background:var(--orange);
  }
  .tl-event-card .tl-card-copy h3{
    font-size:clamp(14px,1.88vw,36px);
  }
  .tl-event-card .tl-card-copy p{
    font-size:clamp(9px,1.1vw,21px);
    line-height:1.18;
  }
  .tl-event-card .tl-year{
    border:1px solid #fff;
    background:var(--orange);
    color:#fff;
  }
  .tl-event-card .tl-card-copy p{ margin-bottom:3%; }

  /* Connector nét chấm giữa thẻ giai đoạn và thẻ sự kiện. */
  .tl-events::before,
  .tl-events.double::after,
  .tl-event-card::before{
    content:"";
    position:absolute;
    z-index:-1;
    border-color:rgba(129,78,0,.72);
    border-style:dashed;
    pointer-events:none;
  }
  .tl-events.single::before{
    top:calc(-1 * var(--event-gap));
    left:50%;
    height:var(--event-gap);
    border-width:0 0 0 1px;
  }
  .tl-events.double::before{
    top:calc(-1 * var(--event-gap));
    left:50%;
    height:calc(var(--event-gap) / 2);
    border-width:0 0 0 1px;
  }
  .tl-events.double::after{
    top:calc(-1 * var(--event-gap) / 2);
    left:25%;
    width:50%;
    border-width:1px 0 0;
  }
  .tl-events.double .tl-event-card::before{
    top:calc(-1 * var(--event-gap) / 2);
    left:50%;
    height:calc(var(--event-gap) / 2);
    border-width:0 0 0 1px;
  }

  /* Đường nối nét đứt "tự vẽ" khi khối lọt vào tầm nhìn (.is-in do client gắn).
     Bọc trong no-preference để khi giảm chuyển động thì đường nối hiện đầy đủ. */
  @media (prefers-reduced-motion:no-preference){
    .tl-events::before,
    .tl-events.double .tl-event-card::before{
      transform:scaleY(0); transform-origin:top center;
      transition:transform .7s cubic-bezier(.2,.7,.2,1) .2s;
    }
    .tl-events.double::after{
      transform:scaleX(0); transform-origin:left center;
      transition:transform .55s cubic-bezier(.2,.7,.2,1) .15s;
    }
    .tl-block.is-in .tl-events::before,
    .tl-block.is-in .tl-events.double .tl-event-card::before{ transform:scaleY(1); }
    .tl-block.is-in .tl-events.double::after{ transform:scaleX(1); transition-delay:.32s; }
  }

  @media(min-width:901px){
    .tl-card-copy .tl-line{
      white-space:nowrap;
    }
  }

  @media(max-width:900px){
    .tl-heading{ width:min(92vw,700px); }
    .tl-kicker,.tl-title{ font-size:clamp(35px,7.2vw,62px); }
    .tl-title{ white-space:normal; }
    .tl-subtitle{ font-size:clamp(12px,2vw,17px); }
    .tl-block{
      --event-gap:48px;
      margin-bottom:76px;
    }
    .tl-era-card{ width:min(72vw,620px); }
    .tl-event-card{ width:min(64vw,550px); }
    .tl-events.double{
      flex-direction:column;
      align-items:center;
      gap:44px;
    }
    .tl-events.double::before{
      height:var(--event-gap);
    }
    .tl-events.double::after{ display:none; }
    .tl-events.double .tl-event-card::before{ display:none; }
    .tl-events.double .tl-event-card + .tl-event-card::before{
      display:block;
      top:-44px;
      left:50%;
      height:44px;
      border-width:0 0 0 1px;
    }
    .tl-decor{
      top:70px;
      height:clamp(230px,45vw,390px);
      background-size:auto 100%;
    }
  }

  @media(max-width:560px){
    #lich-su{ padding-top:64px; padding-bottom:52px; }
    .tl-heading{ margin-bottom:64px; }
    .tl-kicker,.tl-title{ font-size:clamp(30px,9.8vw,48px); }
    .tl-subtitle{ max-width:34ch; }
    .tl-era-card{ width:88vw; }
    .tl-event-card{
      width:82vw;
      height:clamp(165px,44vw,210px);
      aspect-ratio:auto;
    }
    .tl-year{ font-size:clamp(22px,7.4vw,34px); }
    .tl-card-copy h3{ font-size:clamp(12px,4vw,18px); }
    .tl-card-copy p{ font-size:clamp(8px,2.65vw,12px); }
    .tl-block{ margin-bottom:64px; }
    .tl-events.double{ gap:36px; }
    .tl-events.double .tl-event-card + .tl-event-card::before{
      top:-36px;
      height:36px;
    }
    .tl-decor{
      top:56px;
      height:220px;
    }
  }
</style>
